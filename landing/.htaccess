# CallGuard AI — Apache config for Linux hosting
# Drop this in the same directory as index.html (typically public_html)

# ─── Canonical host: force https://callguardai.co.uk (no www) ────────────
# Every variant (http, www, http+www) ends up at the same URL in a single
# 301 hop. This avoids "Page with redirect" warnings in Search Console
# and stops link equity from being split across two hosts.
RewriteEngine On

# Strip "www." and force HTTPS in one go
RewriteCond %{HTTP_HOST} ^www\.callguardai\.co\.uk$ [NC]
RewriteRule ^ https://callguardai.co.uk%{REQUEST_URI} [L,R=301]

# Force HTTPS for the bare host
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://callguardai.co.uk%{REQUEST_URI} [L,R=301]

# ─── Legacy URLs: /alternatives/* moved to /compare/* ────────────────────
RewriteRule ^alternatives/callminer/?$ /compare/callminer-alternative [R=301,L]
RewriteRule ^alternatives/observe-ai/?$ /compare/observe-ai-alternative [R=301,L]

# ─── Pretty URLs: /privacy -> /privacy.html ──────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# ─── Strip .html from URL when user types it directly ────────────────────
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ─── Security headers ────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # HSTS — tells browser to use HTTPS only for the next year
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

  # Browser MIME-sniff guard
  Header set X-Content-Type-Options "nosniff"

  # Block clickjacking
  Header set X-Frame-Options "DENY"

  # Limit referrer leakage
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions-Policy — disable APIs we don't use
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

  # CSP — self-hosted, plus Google Analytics (gtag.js + collect endpoints).
  # GA only fires after cookie consent; these allowances do not load anything by themselves.
  Header set Content-Security-Policy "default-src 'self'; img-src 'self' data: https://www.google-analytics.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self' https://www.googletagmanager.com; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' mailto:"
</IfModule>

# ─── Caching for static assets ───────────────────────────────────────────
# CSS, fonts and images are versioned via querystring (?v=N) or stable
# filenames, so we can safely cache them aggressively. HTML stays short.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
  # Mark long-cached assets as immutable for browsers that honour it
  <FilesMatch "\.(woff2|svg|png|jpe?g|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Ensure the right MIME type is sent for variable woff2
<IfModule mod_mime.c>
  AddType font/woff2 .woff2
</IfModule>

# ─── GZIP compression ────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/xml application/json image/svg+xml
</IfModule>

# ─── Default page ────────────────────────────────────────────────────────
DirectoryIndex index.html

# ─── Hide hidden files from public access ────────────────────────────────
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# ─── Custom error pages ──────────────────────────────────────────────────
# Serve a real 404 page that returns a 404 status. Pointing this at a static
# file (not index.html) means Apache responds with the correct 404 code, which
# avoids "soft 404" warnings in Search Console and keeps dead URLs out of the
# index. The pretty-URL rule above must not rewrite a missing path to .html,
# so exclude /404 itself is unnecessary — the file exists and is served directly.
ErrorDocument 404 /404.html
