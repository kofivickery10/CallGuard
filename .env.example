# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://localhost:5432/callguard

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-string

# Encryption key for SFTP credentials (32 bytes hex). NEVER change once in use.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# File uploads (local directory, defaults to ./uploads)
# UPLOADS_DIR=./uploads

# Deepgram
DEEPGRAM_API_KEY=

# Resend (transactional email for alerts)
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@callguard.app

# Email address that gets notified of new demo requests (optional)
DEMO_REQUEST_EMAIL=

# Public URL for links in alert emails
APP_URL=http://localhost:5173

# Anthropic (Claude)
ANTHROPIC_API_KEY=
