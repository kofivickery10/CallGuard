# ─────────────────────────────────────────────────────────────────────────
# CallGuard environment. Copy to .env and fill in. Values marked (required in
# production) are hard-required when NODE_ENV=production — the process fails
# fast at boot rather than failing every job at runtime.
# ─────────────────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# Number of trusted reverse-proxy hops in front of the API (Cloudflare + nginx
# = 2). Sets Express `trust proxy` so rate-limit / audit IPs are the real client
# IP, not the proxy's. Wrong value = broken rate limiting. Default 1.
TRUST_PROXY_HOPS=1

# Comma-separated list of origins allowed by CORS (the web + admin app URLs).
# Required in production; localhost dev origins are allowed by default.
# ALLOWED_ORIGINS=https://app.callguard.example,https://admin.callguard.example

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/callguard
# PEM CA bundle for the managed Postgres provider. WITHOUT this, TLS runs with
# rejectUnauthorized:false (unverified). Strongly recommended in production.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# ── Redis (BullMQ queues + worker heartbeat) ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth / crypto ────────────────────────────────────────────────────────────
# (required in production) Signs all JWTs. Rotating it forces re-login.
JWT_SECRET=change-me-to-a-long-random-string
# (required always) 32-byte hex key encrypting SFTP/Zoho/dialer creds + audio
# at rest. NEVER change once data exists — it cannot decrypt old data. Escrow it.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Storage ──────────────────────────────────────────────────────────────────
# Local encrypted-disk storage (the deliberate choice — no S3). Back this
# directory up alongside Postgres. Defaults to ./uploads.
# UPLOADS_DIR=./uploads

# ── Transcription (Deepgram) ─────────────────────────────────────────────────
# (required in production)
DEEPGRAM_API_KEY=
# EU endpoint by default for UK/EU data residency. Override only if needed.
# DEEPGRAM_URL=https://api.eu.deepgram.com

# ── Scoring (Anthropic Claude) ───────────────────────────────────────────────
# (required in production)
ANTHROPIC_API_KEY=

# Default adviser stereo channel (0=left, 1=right) when a tenant hasn't set one.
# ADVISER_CHANNEL=

# ── Email (Resend) ───────────────────────────────────────────────────────────
# (required in production) Transactional email for tenant + ops alerts.
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@callguardai.co.uk
# Internal ops inbox for infra alerts (jobs failing after all retries). Empty
# disables ops alerting (a warning is logged when a job would have alerted).
OPS_ALERT_EMAIL=
# Where new demo-request notifications go (optional).
DEMO_REQUEST_EMAIL=

# ── URLs ─────────────────────────────────────────────────────────────────────
# Public URL of the app; used in alert-email links and the Zoho redirect URI.
APP_URL=http://localhost:5173
# Override only if the Zoho OAuth redirect differs from {APP_URL}/api/integrations/zoho/callback
# ZOHO_REDIRECT_URI=

# ── Bootstrap / misc ─────────────────────────────────────────────────────────
# Seed superadmin (used by the seed script / first boot). Set strong values.
# SUPERADMIN_EMAIL=
# SUPERADMIN_PASSWORD=
# Password for the seeded demo tenant admin (seed-demo script only).
# DEMO_ADMIN_PASSWORD=
# FX rate for USD→GBP cost reporting. Default is a sane constant.
# USD_TO_GBP=0.79
